# Copy to .env — do not commit .env
# See docs/ENV-CONFIG.md

NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

ADMIN_PRICING_KEY=change-me-for-pricing-cron-and-admin-endpoint

S3_ENDPOINT=
S3_REGION=ap-south-1
S3_BUCKET=1stopmandi-dev
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

SMS_PROVIDER=mock
MSG91_AUTH_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Used by scripts/update-pricing.js (optional if same shell as server)
API_BASE_URL=http://localhost:3000

# Cashfree Payment Gateway
CASHFREE_CLIENT_ID=        # App ID from Cashfree dashboard (sandbox)
CASHFREE_CLIENT_SECRET=    # Secret key from Cashfree dashboard (sandbox)
CASHFREE_ENV=sandbox       # sandbox | production
